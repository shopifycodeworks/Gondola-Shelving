<aside id="cartSlideoutAside">
	<form
		action="{{ routes.cart_url }}"
		data-language-url="{{ localization.language.root_url }}"
		method="post"
		novalidate
		class="cart-drawer-form"
	>
		<div
			id="cartSlideoutWrapper"
			class="envy-shopping-right slideout-panel-hidden cart-drawer-right"
			role="dialog"
			aria-labelledby="cart_dialog_label"
			aria-describedby="cart_dialog_status"
			aria-modal="true"
		>
			<div class="cart-drawer__top">
				<div class="cart-drawer__empty-div"></div>
				<h2 class="type-subheading type-subheading--1 wow fadeIn" id="cart_dialog_label">
					<span class="cart-drawer--title">{{ 'cart.general.title' | t }}</span>
				</h2>

				<div class="cart-close-icon-wrapper">
					<button
						class="slide-menu cart-close-icon cart-menu-close alt-focus"
						aria-label="{{ 'cart.general.close_cart' | t }}"
						type="button"
					>
						<i data-feather="x"></i>
					</button>
				</div>
			</div>

			<div class="cart-error-box"></div>

			<div aria-live="polite" class="cart-empty-box">
				{{ 'cart.general.empty' | t }}
			</div>

			<script type="application/template" id="cart-item-template">
				<li>
					<article class="cart-item">
						<div class="cart-item-image--wrapper">
							<a class="cart-item-link" href="{{ product.url }}" tabindex="-1">
								<img
									class="cart-item-image"
									src="/product/image.jpg"
									alt=""
								/>
							</a>
						</div>
						<div class="cart-item-details--wrapper">
							<h3 class="cart-item__title">
								<a href="{{ product.url }}" class="cart-item-link cart-item-details--product-title-wrapper">
									<span class="cart-item-product-title"></span>
									<span class="cart-item-variant-title hide"></span>
									<span class="cart-item-selling-plan hide"></span>
								</a>
							</h3>

							<div class="cart-item-price-wrapper">
								<span class="sr-only">{{ 'products.general.now_price' | t }}</span>
								<span class="cart-item-price"></span>
								<span class="sr-only">{{ 'products.general.was_price' | t }}</span>
								<span class="cart-item-price-original"></span>
								<span class="cart-item-price-per-unit"></span>
							</div>

							<ul class="order-discount--cart-list" aria-label="{{ 'customer.order.discount' | t }}"></ul>

							<div class="cart-item--quantity-remove-wrapper">
								<div class="cart-item--quantity-wrapper">
									<button
										type="button"
										class="alt-focus cart-item-quantity-button cart-item-decrease"
										data-amount="-1"
										aria-label="Reduce item quantity by one"
									>-</button>
									<input
										type="text"
										class="cart-item-quantity"
										min="1"
										pattern="[0-9]*"
										aria-label="Quantity"
									>
									<button
										type="button"
										class="alt-focus cart-item-quantity-button cart-item-increase"
										data-amount="1"
										aria-label="Increase item quantity by one"
									>+</button>
								</div>

								<div class="cart-item-remove-button-container">
									<button type="button" id="cart-item-remove-button" class="alt-focus" aria-label="Remove product">{{ 'cart.general.remove' | t }}</button>
								</div>
							</div>

              <div class="errors hide"></div>
						</div>
					</article>
				</li>
			</script>
			<script type="application/json" id="initial-cart">
				{{ cart | json }}
			</script>

			<ul class="cart-items"></ul>

			<div class="ajax-cart--bottom-wrapper">
				{% if settings.allow_note %}
				<div class="ajax-cart--checkout-add-note">
						<p>{{ 'cart.general.note' | t }}&hellip;</p>
						<textarea id="note" name="note" class="form-control">{{ cart.note }}</textarea>
				</div>
				{% endif %}

				<div class="ajax-cart--cart-discount">
					<div class="cart--order-discount-wrapper custom-font ajax-cart-discount-wrapper"></div>
				</div>

				<span class="cart-price-text type-subheading">{{ 'cart.general.subtotal' | t }}</span>

				<div class="ajax-cart--cart-original-price">
					<span class="cart-item-original-total-price"><span class="money">{{ cart.original_total_price | money }}</span></span>
				</div>

				<div class="ajax-cart--total-price">
					<h2
						id="cart_dialog_status"
						role="status"
						class="js-cart-drawer-status sr-only"
					></h2>

					<h5 id="cart_drawer_subtotal">
						<span class="cart-total-price" id="cart-price">
							<span class="money">{{ cart.total_price | money }}</span>
						</span>
					</h5>
				</div>

				{%- capture taxes_shipping_checkout -%}
					{%- if shop.taxes_included and shop.shipping_policy.body != blank -%}
						{{ 'cart.general.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url }}
					{%- elsif shop.taxes_included -%}
						{{ 'cart.general.taxes_included_but_shipping_at_checkout' | t }}
					{%- elsif shop.shipping_policy.body != blank -%}
						{{ 'cart.general.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url }}
					{%- else -%}
						{{ 'cart.general.taxes_and_shipping_at_checkout' | t }}
					{%- endif -%}
				{%- endcapture -%}

				<div class="row">
					<div class="col-md-12">
						<p class="cart--shipping-message">{{ taxes_shipping_checkout }}</p>
					</div>
				</div>

				<div class="slide-checkout-buttons">
					<button type="submit" name="checkout" class="btn cart-button-checkout">
						<span class="cart-button-checkout-text">{{ 'cart.general.checkout' | t }}</span>
						<div class="cart-button-checkout-spinner lds-dual-ring hide"></div>
					</button>
					{% if additional_checkout_buttons and settings.enable-additional-checkout-buttons %}
						<div class="additional-checkout-buttons">
							{{ content_for_additional_checkout_buttons }}
						</div>
					{% endif %}
					{% if settings.enable_continue_shopping %}
						<a href="#" class="btn btn-default cart-menu-close secondary-button">{{ 'layout.cart.continue_shopping' | t }}</a><br />
					{% endif %}
				</div>

			</div>
		</div>
	</form>
</aside>

<script>
	(function () {
		'use strict';

		var listenersAttached = false;

		function applyEndcapRules(cartData) {
			var items = document.querySelectorAll('.cart-items > li');
			if (!items || !items.length) return;

			items.forEach(function (li, idx) {
				var cartItem = cartData.items[idx];
				if (!cartItem || !cartItem.properties) return;

				var isEndcap = String(cartItem.properties['_is_endcap'] || '') === '1';
				var groupId = String(cartItem.properties['_group_id'] || cartItem.properties['Group ID'] || '');

				li.setAttribute('data-group-id', groupId);
				li.setAttribute('data-is-endcap', isEndcap ? '1' : '0');

				if (isEndcap) {
					var qtyWrapper = li.querySelector('.cart-item--quantity-wrapper');
					if (qtyWrapper) qtyWrapper.style.cssText = 'display:none !important';

					var removeContainer = li.querySelector('.cart-item-remove-button-container');
					if (removeContainer) removeContainer.style.cssText = 'display:none !important';

					var staticQty = li.querySelector('.endcap-static-qty');
					if (!staticQty) {
						staticQty = document.createElement('span');
						staticQty.className = 'endcap-static-qty';
						staticQty.style.cssText = 'display:inline-block;padding:4px 8px;font-size:14px;font-weight:500;';
						var qtyRow = li.querySelector('.cart-item--quantity-remove-wrapper');
						if (qtyRow) qtyRow.insertBefore(staticQty, qtyRow.firstChild);
					}
					staticQty.textContent = cartItem.quantity;
				}
			});
		}

		function findEndcapLi(mainLi) {
			var groupId = mainLi.getAttribute('data-group-id');
			if (!groupId) return null;
			var allLis = document.querySelectorAll('.cart-items > li');
			for (var i = 0; i < allLis.length; i++) {
				var li = allLis[i];
				if (li !== mainLi &&
					li.getAttribute('data-is-endcap') === '1' &&
					li.getAttribute('data-group-id') === groupId) {
					return li;
				}
			}
			return null;
		}

		function attachGroupListeners() {
			if (listenersAttached) return;
			listenersAttached = true;

			document.addEventListener('click', function (e) {
				var qtyBtn = e.target.closest('.cart-items .cart-item-quantity-button');
				if (qtyBtn) {
					var li = qtyBtn.closest('li');
					if (!li) return;
					if (li.getAttribute('data-is-endcap') === '1') {
						e.stopImmediatePropagation();
						return;
					}
					var endcapLi = findEndcapLi(li);
					if (endcapLi) {
						var mainQtyInput = li.querySelector('.cart-item-quantity');
						var current = parseInt(mainQtyInput ? mainQtyInput.value : '0', 10) || 0;
						var change = parseInt(qtyBtn.getAttribute('data-amount'), 10) || 0;
						var newQty = Math.max(0, current + change);
						var ecInput = endcapLi.querySelector('.cart-item-quantity');
						if (ecInput) ecInput.value = newQty;
						var staticSpan = endcapLi.querySelector('.endcap-static-qty');
						if (staticSpan) staticSpan.textContent = newQty;
					}
					return;
				}

				var removeBtn = e.target.closest('.cart-items .cart-item-remove-button-container button');
				if (!removeBtn) return;
				var lineLi = removeBtn.closest('li');
				if (!lineLi) return;
				if (lineLi.getAttribute('data-is-endcap') === '1') {
					e.stopImmediatePropagation();
					return;
				}
				var linkedEndcap = findEndcapLi(lineLi);
				if (linkedEndcap) {
					var endcapQtyInput = linkedEndcap.querySelector('.cart-item-quantity');
					if (endcapQtyInput) endcapQtyInput.value = 0;
				}
			}, true);

			document.addEventListener('change', function (e) {
				var input = e.target;
				if (!input || !input.classList.contains('cart-item-quantity')) return;
				var li = input.closest('li');
				if (!li || li.getAttribute('data-is-endcap') === '1') return;
				var endcapLi = findEndcapLi(li);
				if (!endcapLi) return;
				var newQty = Math.max(0, parseInt(input.value, 10) || 0);
				var endcapQtyInput = endcapLi.querySelector('.cart-item-quantity');
				if (endcapQtyInput) endcapQtyInput.value = newQty;
				var staticSpan = endcapLi.querySelector('.endcap-static-qty');
				if (staticSpan) staticSpan.textContent = newQty;
			}, true);
		}

		function refreshDrawerEndcapRules() {
			fetch('{{ routes.cart_url }}.js')
				.then(function (r) { return r.json(); })
				.then(function (cart) {
					applyEndcapRules(cart);
					attachGroupListeners();
				})
				.catch(function () {});
		}

		function setupObserver() {
			var target = document.getElementById('cartSlideoutAside') || document.querySelector('.cart-items');
			if (!target || typeof MutationObserver === 'undefined') return;
			var useSubtree = target.id === 'cartSlideoutAside';
			new MutationObserver(function (mutations) {
				var hasAdded = mutations.some(function (m) { return m.addedNodes && m.addedNodes.length > 0; });
				if (hasAdded) {
					clearTimeout(window._ecDebounce);
					window._ecDebounce = setTimeout(refreshDrawerEndcapRules, 120);
				}
			}).observe(target, { childList: true, subtree: useSubtree });
		}

		function init() {
			refreshDrawerEndcapRules();
			setupObserver();
			var polls = 0;
			var poller = setInterval(function () {
				refreshDrawerEndcapRules();
				if (++polls >= 8) clearInterval(poller);
			}, 500);
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', init);
		} else {
			init();
		}
	})();
</script>
