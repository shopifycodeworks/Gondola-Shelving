    <script defer="defer" src="{{ 'track-record.js' | asset_url }}"></script>
    <script defer="defer" src="{{ 'slick.min.js' | asset_url }}"></script>
    <script defer="defer" src="{{ 'enquire.min.js' | asset_url }}"></script>
    {% if template contains 'customers' %}
      {{ 'shopify_common.js' | shopify_asset_url | script_tag }}
      {{ 'customer_area.js' | shopify_asset_url | script_tag }}
    {% endif %}
    <!-- <script src="{{ 'custom.js' | asset_url }}" defer="defer"></script> -->
    <script src="{{ 'product-grid-size-updater.js' | asset_url }}" defer="defer"></script>

    {% if template.name == 'article' %}
      <script src="{{ 'textSlideshow.js' | asset_url }}" defer="defer"></script>
    {% endif %}

