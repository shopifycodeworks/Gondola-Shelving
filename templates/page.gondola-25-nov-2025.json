            "customization_block_desc": "<p>Plug-and-play refrigeration units with built-in compressors that are easy to install, move, and service—ideal for smaller stores or cost-conscious projects that still need reliable, attractive cold display.</p>"
          }
        },
        "customization_wXBH4z": {
