    "gandola_text_half_rFWwiJ": {
      "type": "gondola-text-half",
      "settings": {
        "heading": "",
        "text_cont": "<h3>Canadian-Made Gondola Shelving That Turns Every Aisle Into Profits</h3><ul><li><strong>Made in Canada</strong> for consistent quality and reliable supply<br/></li><li><strong>Solid structure, lifetime build</strong> to handle real retail loads every day<br/></li><li><strong>Custom dimensions and colours</strong> to match your brand and floor plan<br/></li><li><strong>Expandable system</strong> that grows with your store<br/></li><li><strong>Easy to install and reconfigure</strong> for new layouts and seasons<br/></li><li><strong>Consistent components and replacement parts</strong> for simple repairs and add-ons</li></ul><h5>When you buy gondola shelving from us, you’re investing in:</h5><ul><li>A team that understands <strong>full store layouts</strong>, not just hardware—so your shelving supports better flow and higher sales<br/></li><li>Fixtures that drive <strong>higher sales per square foot</strong><br/></li><li>A <strong>professional, consistent look</strong> across your store<br/></li><li><strong>Local manufacturing and accountability</strong><br/></li><li><strong>Long-term durability</strong> instead of short-term, disposable fixtures</li></ul><p>You invest once in solid, Canadian-made shelving—and it pays you back every day your store is open.</p><p></p><p><a href=\"https://drive.google.com/file/d/1B9fIJVib4rt4ofoaH-rJldXu_HH9D8Ld/view?usp=sharing\" target=\"_blank\" title=\"VIEW CATALOG\">VIEW CATALOG</a></p>",
        "button_label": "Book A Consultation",
        "button_link": "https://vanguardstorefixtures.com/pages/contact",
        "custom_class": "gandola_half_anchor"
      }
    },
