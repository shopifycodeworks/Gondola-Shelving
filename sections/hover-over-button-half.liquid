// });

// $('.hotspots').each(function(e, i) {
//   var $this = $(this);
//   var css = detectPosition($this, e);
//   $(this).addClass(css.css).attr('style', css.styles);
// });
 $('.hotspots .icon').on('mouseenter', function() {
    var $parent = $(this).parent();
    $parent.addClass('open');
    $('.hotspots').not($parent).removeClass('open');
  });

  $('.hotspots').on('mouseleave', function() {
    $(this).removeClass('open');
  });
function detectPosition($elem, ind) {
  var container = $('.hover-over-image .container'),
    height = container.innerHeight(),
    width = container.innerWidth(),
    p = $elem.position(),
    x = p.left,
    y = p.top,
    w = $elem.width(),
    h = $elem.height(),

    cssClass = [],
    style = '';

  if (x >= width / 2) { // Right half
    cssClass.push('right');
    style += 'right:' + ((width - x - w) / width * 100) + '%;left: auto;';

  } else { // Left half
    cssClass.push('left');
    style += 'left:' + (x / width * 100) + '%;right: auto;';

  }

  if (y >= height / 2) { // Lower half
    cssClass.push('bottom');
    style += 'bottom:' + ((height - y - h) / height * 100) + '%;top: auto;';

  } else { // Upper half
    cssClass.push('top');
    style += 'top:' + (y / height * 100) + '%;bottom: auto;';
  }

  return {
    css: cssClass.join('-'),
    styles: style
  };
}
</script>
