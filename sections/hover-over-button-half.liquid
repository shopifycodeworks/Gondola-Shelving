<div class="hover-over-image {{ section.settings.custom_class }}">  
  <div class='container'>
    <img src="{{ section.settings.hover_image | img_url: 'master' }}" class="main_hotspot_image">
    {% for block in section.blocks %}
   {% assign styles = '' %}
      {% if block.settings.space_bottom != 0 %}{% assign styles = styles | append: 'bottom:' | append: block.settings.space_bottom | append: '%;' %}{% endif %}
      {% if block.settings.space_top != 0 %}{% assign styles = styles | append: 'top:' | append: block.settings.space_top | append: '%;' %}{% endif %}
      {% if block.settings.space_left != 0 %}{% assign styles = styles | append: 'left:' | append: block.settings.space_left | append: '%;' %}{% endif %}
      {% if block.settings.space_right != 0 %}{% assign styles = styles | append: 'right:' | append: block.settings.space_right | append: '%;' %}{% endif %}
      
    <div class='hotspots' style='{{ styles }}'>
      <div class='icon triangle'>&#9650;</div>
      <div class='content'>
        {% if block.settings.heading_title != blank %} 
          <h4>{{ block.settings.heading_title }}</h4> 
          {% endif %}
         {% if block.settings.description_content != blank %} 
           <p>{{ block.settings.description_content }}</p>
          {% endif %}
        {% if block.settings.button__txt != blank %}
        <a class='btn' href='{{ block.settings.Button }}'>
          {{ block.settings.button__txt }}
        </a>
        {% endif %}
      </div>
    </div>
    {% endfor %}
    {% comment %}
    <div class="catalog_btn">
      <div class="catalog_inner_txt" id="catalogBtn">
        <img src="{{ 'open-book.png' | asset_url }}"/>
        <span class="catalog_txt">View </br>Catalog</span>
      </div>
    </div>
    {% endcomment %}
  </div>
</div>

    {% comment %}
<div id="myModalPdf" class="modal">
  <div class="modal-content">
    <span class="closing">&times;</span>
    <embed src="https://cdn.shopify.com/s/files/1/0784/4941/0346/files/Modern_Store_Shelving_Planning_Guide.pdf?v=1719397666" frameborder="0" width="100%" height="90%">
  </div>
</div>

<script>
var modal = document.getElementById("myModalPdf");
var btn = document.getElementById("catalogBtn");
var span = document.getElementsByClassName("closing")[0];
btn.onclick = function() {
  modal.style.display = "block";
}
span.onclick = function() {
  modal.style.display = "none";
}
window.onclick = function(event) {
  if (event.target == modal) {
    modal.style.display = "none";
  }
}
</script>
    {% endcomment %}

{% schema %}
  {
    "name": "Hover Over Buttons Half",
    "tag": "section",
    "class": "hover-buttons hover-buttons-half",
    "settings": [
        {
          "type": "image_picker",
          "id": "hover_image",
          "label": "Main Image"
        },
        {
          "type": "text",
          "id": "custom_class",
          "label": "Custom Class"
        }      
    ],
    "blocks": [
      {
        "type": "hotspot",
        "name": "Hotspot",
        "settings": [
          {
            "type": "richtext",
            "label": "Heading",
            "id": "heading_title"
          },
          {
            "type": "richtext",
            "label": "Description",
            "id": "description_content"
          },
          {
            "type": "text",
            "label": "Button Title",
            "id": "button__txt"
          },
          {
            "type": "url",
            "label": "Button Url",
            "id": "button_url"
          },
          {
            "type": "range",
            "id": "space_top",
            "min": 0,
            "max": 100,
            "step": 1,
            "label": "top",
            "default": 0
          },
          {
            "type": "range",
            "id": "space_bottom",
            "min": 0,
            "max": 100,
            "step": 1,
            "label": "Bottom",
            "default": 0
          },
          {
            "type": "range",
            "id": "space_right",
            "min": 0,
            "max": 100,
            "step": 1,
            "label": "right",
            "default": 0
          },
          {
            "type": "range",
            "id": "space_left",
            "min": 0,
            "max": 100,
            "step": 1,
            "label": "left",
            "default": 0
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Hover Over Buttons Half"
      }
    ]
  }
{% endschema %}
<script>
