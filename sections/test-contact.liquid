{{ 'section-contact-form.min.css' | asset_url | stylesheet_tag }}


<section class="section-contact-form homepage-sections-wrapper--" data-wetheme-section-type="contact-form"> 
  <!-- <div class="contact-form--wrapper"> -->

      {% assign content_header = false %}

      <!-- {% unless section.blocks.size == 0 %} -->
        <!-- <div class="{% if settings.animations_enabled %} wow fadeIn{% if content_header %} delay-1{% endif %}{% endif %}"> -->
          <!-- {% form 'contact', id: 'ContactFormprod', class: 'contact-form--form' %} -->
<form method="post" action="/contact#ContactForm" id="ContactForm" accept-charset="UTF-8" class="contact-form--form">
            {% render 'form-errors-custom', form: form %}
            {% if form.posted_successfully? %}
              <div class="w-full">
                <p class="note form-success">
                  {{ 'contact.form.post_success' | t }}
                </p>
              </div>
            {% endif %}

            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'tel_input' %}
                  <div class="input_width">
                    {% liquid
                      assign telInputString = 'contact.form.phone' | t
                      assign formTelName = 'contact[' | append: telInputString | append: ']'
                      assign labelInput = telInputString | prepend: requiredSymbol
                      assign formId = 'form_' | append: telInputString | downcase | handleize
                      assign input_attr = 'aria-labelledby="' | append: formId | append: '" data-aid="tel-input"'
                      if form.phone
                        assign phoneInputVal = form.phone
                      elsif customer
                        assign phoneInputVal = customer.phone
                      endif

                      render 'form-input' with type: 'tel', classes:'form-control contactPhone',placeholder: labelInput,has_label: false, animate_label: false, label_text: labelInput, id: formId, value: phoneInputVal, name: formTelName, required: block.settings.required, attributes: input_attr 
                    %}
                  </div>
              {% endcase %}
            {% endfor %}
            {{ 'shopify.online_store.spam_detection.disclaimer_html' | t }}
            <div class="contact-form--submit-wrapper w-full">
              <input type="submit" class="btn btnLg" value="Send message">
            </div>
          <!-- {% endform %} -->
</form>
        <!-- </div> -->
      {% else %}
        <div class="placeholder-noblocks{% if settings.animations_enabled %} wow fadeIn{% if content_header %} delay-1{% endif %}{% endif %}">
          {{ 'general.onboarding.no_content' | t }}
        </div>
      <!-- {% endunless %} -->
  <!-- </div> -->
</section>

{% schema %}
{
  "name": "Test Contact form",
  "class": "shopify-section homContactSec sec-gapTop",
  "settings": [
  ],
  "blocks": [
    {
      "name": "Telephone field",
      "type": "tel_input",
      "limit": 1
    }
  ],
  "presets": [
    {
      "name": "Test Contact form",
      "settings": {
      }
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}