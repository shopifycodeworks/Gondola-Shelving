<style>
  .extra-features img.extra-feature-image {
    border: 1px solid #ccc;
    padding: 10px;
    margin-bottom: 20px;
}
  .extra-features h4.type-subheading {    
    color: #CC0000 !important;
    line-height: 1;
    text-transform: capitalize;
}
  .extra-features .service-col {
    text-align: center;
}
  .extra-features .service-col .info-columns--text p {
    font-size: 12px;
}
  .extra-features .common-btn.btn.btnBlack.btnLg{
    background-color: #CC0000 !important;
  }


  
#myModalPdf1{
  display: none;
  position: fixed;
  z-index: 999;
  padding-top: 50px;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  overflow: auto;
  background-color: rgb(0,0,0);
  background-color: rgba(0,0,0,0.4);
}

#myModalPdf1 .modal-content {
  background-color: #fefefe;
  margin: auto;
  padding: 20px;
  border: 1px solid #888;
  width: 80% !important;
  height: 80%;
}

#myModalPdf1 .closing1 {
  color: #aaaaaa;
  float: right;
  font-size: 28px;
  font-weight: bold;
  text-align: right;
}

#myModalPdf1 .closing1:hover,
#myModalPdf1 .closing1:focus {
  color: #000;
  text-decoration: none;
  cursor: pointer;
}
@media only screen and (max-width: 600px){
  .extra-features .service-col {
    padding-bottom: 0 !important;
}
  .extra-features .service-col .info-columns--text {
    margin-bottom: 0 !important;
}
  .extra-features .store-about-slider-wrap.comm-padd {
    padding-bottom: 40px !important;
}
}
</style>

<div class="store-about-slider-wrap comm-padd ">
  
<div class="container">
  {% if section.settings.heading != blank %}
    <h3 class="heading">{{ section.settings.heading }}</h3>
  {% endif %}
  <div class="owl-carousel owl-theme" id="features-slider">
    {% for block in section.blocks %}
      <div class="item">
        <div class="service-col">
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | img_url: 'master' }}" class="extra-feature-image" alt="{{ block.settings.image.alt | escape }}">
          {% endif %}
          {% if block.settings['slider-heading'] != blank %}
            <h4 class="type-subheading type-subheading--1 info-columns--title">
              {{ block.settings['slider-heading'] }}
            </h4>
          {% endif %}
          <div class="info-columns--text">
            {% if block.settings.desc != blank %}
              <p>{{ block.settings.desc }}</p>
            {% endif %}
            {% if block.settings.btn_text != blank %}
              <a href="{{ block.settings.btn_link }}" class="a-text">{{ block.settings.btn_text }}</a>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
  {% if section.settings.button_label != blank and section.settings.button_link != blank %}
    <div class="row">
      <div class="col-md-12">
        <div class="common-btnBtn-bookConsultation text-center" id="myModalPdf1">
          <a href="{{ section.settings.button_link }}" class="common-btn btn btnBlack btnLg">
            {{- section.settings.button_label -}}
          </a>
        </div>
      </div>
    </div>
  {% endif %}
    <div class="row">
      <div class="col-md-12">
        <div class="common-btnBtn-bookConsultation text-center">
          {% comment %}
          <span href="" class="common-btn btn btnBlack btnLg" id="viewCatalog">
            View Catalog
          </span>
          {% endcomment %}
          <a href="#" class="common-btn btn btnBlack btnLg" id="viewCatalog">View Catalog</a>
        </div>
      </div>
    </div>

<div id="myModalPdf1" class="modal">
  <div class="modal-content">
    <span class="closing1">&times;</span>
    <embed src="https://cdn.shopify.com/s/files/1/0784/4941/0346/files/Vanguard_Shelving_Catalogue.pdf?v=1719440966" frameborder="0" width="100%" height="90%">
  </div>
</div>

<script>
var modal = document.getElementById("myModalPdf1");
var btn = document.getElementById("viewCatalog");
var span = document.getElementsByClassName("closing1")[0];
btn.onclick = function() {
  modal.style.display = "block";
}
span.onclick = function() {
  modal.style.display = "none";
}
window.onclick = function(event) {
  if (event.target == modal) {
    modal.style.display = "none";
  }
}
</script>
</div>

</div>
{% schema %}
{
  "name": "Gandola Extra Features",
  "tag": "section",
  "class": "extra-features",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading"
    },
     {
      "type": "text",
      "id": "button_label",
      "label": "Button Label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Select Image"
        },
        {
          "type": "text",
          "id": "slider-heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "desc",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gandola Extra Features"
    }
  ]
}
{% endschema %}
