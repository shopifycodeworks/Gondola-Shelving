                "de": "Logobreite",
                "es": "Ancho del logotipo",
                "fr": "Largeur du logo",
                "pt-PT": "Largura do logótipo"
            },
            "min": 100,
            "max": 240,
            "step": 10,
            "unit": {
                "en": "px",
                "de": "px",
                "es": "px",
                "fr": "px",
                "pt-PT": "px"
            },
            "default": 150
        },
        {
            "type": "text",
            "id": "subheading",
            "label": {
              "en": "Subheading",
              "de": "Unterüberschrift",
              "es": "Subencabezado",
              "fr": "Sous-rubrique",
              "pt-PT": "Subtítulo"
            }
        },
        {
            "type": "text",
            "id": "title",
            "label": {
                "en": "Heading",
                "de": "Überschrift",
                "es": "Encabezado",
                "fr": "Rubrique",
                "pt-PT": "Título"
            },
            "default": {
                "en": "As seen in",
                "de": "Wie gesehen in",
                "es": "Visto en",
                "fr": "Comme on peut le voir dans",
                "pt-PT": "Conforme visto em"
            }
        },
        {
            "type": "header",
            "content": "Section spacing"
        },
        {
            "type": "select",
            "id": "section_width",
            "label": "Width",
            "options": [
                {
                    "value": "container-full-width",
                    "label": "Full width"
                },
                {
