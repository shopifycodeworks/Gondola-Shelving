    "presets": [
        {
            "name": {
                "en": "Logo list",
                "de": "Logoliste",
                "es": "Lista de logotipos",
                "fr": "Liste des logos",
                "pt-PT": "Lista de logótipos"
            },
            "category": {
                "en": "Image",
                "de": "Bild",
                "es": "Imagen",
                "fr": "Image",
                "pt-PT": "Imagem"
            },
            "blocks": [
                {
                    "type": "logo_image"
                },
                {
                    "type": "logo_image"
                },
                {
                    "type": "logo_image"
                },
                {
                    "type": "logo_image"
                }
            ]
        }
