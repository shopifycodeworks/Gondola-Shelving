<div class="title-bar wrapper--page-title">
  <h2>{{ 'cart.general.title' | t }}</h2>
</div>

{% if cart.item_count == 0 %}
  <div class="empty-cart">
    {{ 'cart.general.empty' | t }},
    <a href="{{ routes.all_products_collection_url }}">{{ 'cart.general.continue_browsing_html' | t }}</a>
  </div>
{% else %}
  <div class="cart-error-box"></div>
  <form
    action="{{ routes.cart_url }}"
    method="post"
    novalidate
    class="cart table-wrap"
    id="cartform"
    data-wetheme-section-type="template--cart"
    data-wetheme-section-id="cart"
  >
    <table class="cart-table full table--responsive" border="0">
      <thead class="cart__row cart__header-labels">
        <th colspan="2" scope="col">Product</th>
        <th class="cart--price-column" scope="col">{{ 'cart.general.price' | t }}</th>
        <th scope="col">{{ 'cart.general.quantity' | t }}</th>
        <th class="cart--final-column" scope="col">{{ 'cart.general.total' | t }}</th>
      </thead>

      <tbody>
        {% for item in cart.items %}
          {% assign is_linked_endcap = false %}
          {% assign group_id = item.properties._group_id | default: item.properties['Group ID'] | default: '' %}
          {% if item.properties._is_endcap == '1' %}
            {% assign is_linked_endcap = true %}
          {% endif %}
          <tr class="{% cycle 'even', 'odd' %} line-item id-{{ item.id }}">
            <td class="cart-table-image">
              <a class="cart_thumb" href="{{item.product.url}}" title="View {{item.title}} Page">
                {% render 'responsive-image' with item, alt: item.image.alt %}
              </a>
            </td>

            <td class="cart-table-title">
              <a class="cart-table-title__title" href="{{ item.url }}" title="View {{ item.title | escape }}">
                {{- item.product.title }}
                <!-- **BEGIN** Hextom USB Integration // Cart Include - DO NOT MODIFY -->
                {% render 'hextom_usb_cart', item: item %}
                <!-- **END** Hextom USB Integration // Cart Include - DO NOT MODIFY -->
              </a>

              {% unless item.variant.title contains 'Default' %}
                <div class="cart__meta-text">
                  {% for option in item.product.options %}
                    <span>{{ option }}</span>: {{ item.variant.options[forloop.index0] -}}
                    <br>
                  {% endfor %}
                </div>
              {% endunless %}

              {% if item.selling_plan_allocation %}
                <div class="cart__meta-text">
                  <span>{{ item.selling_plan_allocation.selling_plan.name }}</span>
                </div>
              {% endif %}

              {% assign property_size = item.properties | size %}
              {% if property_size > 0 %}
                <br>
                <div class="cart__meta-text">
                  {% for p in item.properties %}
                    {% if p.last != blank and p.first.first != '_' %}
                      <span>
                        {{ p.first }}:
                        {% comment %}
                          Check if there was an uploaded file associated
                        {% endcomment %}
                        {% if p.last contains '/uploads/' %}
                          <a href="{{ p.last }}">{{ p.last | split: '/' | last }}</a>
                        {% else %}
                          {{ p.last }}
                        {% endif %}
                      </span>
                      <br>
                    {% endif %}
                  {% endfor %}
                </div>
              {% endif %}

              {% unless is_linked_endcap %}
                <div class="cart-table-item-remove cart-table-item-remove--desktop">
                  <a
                    href="{{ routes.cart_url }}/change?line={{ forloop.index }}&amp;quantity=0"
                    class="js-group-remove"
                    data-line="{{ forloop.index }}"
                    data-group-id="{{ group_id | escape }}"
                  >
                    {{- 'cart.general.remove' | t -}}
                  </a>
                </div>
              {% endunless %}
            </td>

            <td class="cart-table-price">
              {%- if item.original_price != item.final_price -%}
                <span class="sr-only">{{ 'products.general.now_price' | t }}</span>
                <span class="order-discount"
                  ><span class="money">{{ item.final_price | money }}</span></span
                >
                <span class="sr-only">{{ 'products.general.was_price' | t }}</span>
                <del
                  ><span class="compare-at-price money">{{ item.original_price | money }}</span></del
                >
              {%- else -%}
                <span class="money">{{ item.original_price | money }}</span>
              {%- endif -%}

              {% if item.unit_price != blank %}
                <span class="cart__price-unit-price">
                  {%- capture unit_price_separator -%}
							<span aria-hidden="true">/</span>
							{%- endcapture -%}
                  {%- capture unit_price_base_unit -%}
							{%- if item.unit_price_measurement.reference_value != 1 -%}
								{{- item.unit_price_measurement.reference_value -}}
							{%- endif -%}
								{{ item.unit_price_measurement.reference_unit }}
							{%- endcapture -%}

                  <span data-unit-price>( {{ item.unit_price | money }}</span>
                  {{- unit_price_separator -}}
                  {{- unit_price_base_unit -}}
                  )
                </span>
              {% endif %}
            </td>

            <td class="cart-table-quantity">
              {% if is_linked_endcap %}
                <span
                  class="quantity-selector quantity-selector--linked-endcap"
                  aria-label="Quantity"
                  data-group-id="{{ group_id | escape }}"
                >
                  {{- item.quantity -}}
                </span>
                <input
                  type="hidden"
                  name="updates[]"
                  class="linked-endcap-quantity-input"
                  data-group-id="{{ group_id | escape }}"
                  value="{{ item.quantity }}"
                >
              {% else %}
                <div
                  class="quantity-controls"
                  data-stock-count="{{ item.variant.inventory_quantity }}"
                  data-inventory-policy="{{ item.variant.inventory_policy }}"
                  data-inventory-management="{{ item.variant.inventory_management }}"
                >
                  <button
                    type="button"
                    class="qty-minus alt-focus"
                    aria-label="Reduce item quantity by one"
                  >
                    -
                  </button>
                  <input
                    id="updates_{{item.variant.id}}"
                    class="number quantity-selector"
                    data-group-id="{{ group_id | escape }}"
                    value="{{item.quantity}}"
                    aria-label="Quantity"
                    name="updates[]"
                    type="text"
                    size="4"
                  >
                  <button
                    type="button"
                    class="qty-plus alt-focus"
                    aria-label="Increase item quantity by one"
                  >
                    +
                  </button>
                </div>
                <div class="stock-error-message d-none">{{ 'cart.general.stock_error' | t }}</div>
              {% endif %}
            </td>

            <td class="cart-table-line-price cart--final-column">
              {%- if item.original_line_price != item.final_line_price -%}
                <div>
                  <span class="sr-only">{{ 'products.general.now_price' | t }}</span>
                  <span class="order-discount"
                    ><span class="money">{{ item.final_line_price | money }}</span></span
                  >
                  <span class="sr-only">{{ 'products.general.was_price' | t }}</span>
                  <del
                    ><span class="compare-at-price money">{{ item.original_line_price | money }}</span></del
                  >
                </div>
              {%- else -%}
                <span class="money">{{ item.original_line_price | money }}</span>
              {%- endif -%}

              {%- if item.line_level_discount_allocations != blank -%}
                <ul class="order-discount--cart-list" aria-label="{{ 'customer.order.discount' | t }}">
                  {%- for discount_allocation in item.line_level_discount_allocations -%}
                    <li class="order-discount--item">
                      {{ discount_allocation.discount_application.title }}
                      <span class="sr-only">{{ 'products.general.saving' | t }} </span>(-<span class="money">
                        {{- discount_allocation.amount | money -}}</span
                      >)
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </td>

            <td class="cart-table-item-remove cart-table-item-remove--mobile">
              {% unless is_linked_endcap %}
                <a
                  href="{{ routes.cart_url }}/change?line={{ forloop.index }}&amp;quantity=0"
                  class="js-group-remove"
                  data-line="{{ forloop.index }}"
                  data-group-id="{{ group_id | escape }}"
                >
                  {{- 'cart.general.remove' | t -}}
                </a>
              {% endunless %}
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>

    <div class="cart-bottom-box">
      {%- if cart.cart_level_discount_applications != blank -%}
        <div class="cart--order-discount-wrapper custom-font">
          {%- for discount_application in cart.cart_level_discount_applications -%}
            <div class="cart--order-discount-wrapper--indiv">
              <span class="order-discount--cart-title">
                <span class="hide">{{ 'customer.order.discount' | t }}:</span>(
                {{- discount_application.title -}}
                )
              </span>
              <span class="order-discount"
                >-<span class="money">{{ discount_application.total_allocated_amount | money }}</span></span
              >
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="cart-totals--wrapper">
        <div id="cart-total-header">{{ 'cart.general.subtotal' | t }}</div>
        <div id="cart-total-final-price">
          <span class="money">{{ cart.total_price | money }}</span>
        </div>
      </div>

      {%- capture taxes_shipping_checkout -%}
      {%- if shop.taxes_included and shop.shipping_policy.body != blank -%}
        {{ 'cart.general.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url }}
      {%- elsif shop.taxes_included -%}
        {{ 'cart.general.taxes_included_but_shipping_at_checkout' | t }}
      {%- elsif shop.shipping_policy.body != blank -%}
        {{ 'cart.general.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url }}
      {%- else -%}
        {{ 'cart.general.taxes_and_shipping_at_checkout' | t }}
      {%- endif -%}
    {%- endcapture -%}

      <div class="row cart-page--bottom">
        <div class="col-md-6 checkout-add-note">
          {% if settings.allow_note %}
            <p>{{ 'cart.general.note' | t }}&hellip;</p>
            <textarea id="note" name="note" class="form-control">{{ cart.note }}</textarea>
          {% endif %}
          &nbsp;
        </div>

        <div class="col-md-6">
          <div class="cart--shipping-message">{{ taxes_shipping_checkout }}</div>
          {% if settings.enable_terms_conditions %}
            <div class="terms-conditions">
              <p>
                <label style="display:inline; float:none">
                  <input
                    style="float:none; vertical-align: middle;"
                    type="checkbox"
                    class="wetheme-custom-checkbox"
                    id="agree"
                    data-terms-agree="{{ 'cart.general.terms_agree' | t | escape }}"
                  >
                  {% if settings.terms_conditions_link == blank %}
                    {{ 'cart.general.terms_text' | t }}
                  {% else %}
                    {{ 'cart.general.terms_text_html' | t | replace: '#', settings.terms_conditions_link }}
                  {% endif %}
                </label>
              </p>
            </div>
          {% endif %}
          <div id="checkout-buttons">
            {% if settings.enable_continue_shopping %}
              <a href="{{ routes.root_url }}" class="btn secondary-button continue-shopping--cart">
                {{- 'layout.cart.continue_shopping' | t -}}
              </a>
            {% endif %}
            <input
              id="update_quantities"
              type="submit"
              value="{{ 'cart.general.update' | t }}"
              title="{{ 'cart.general.update' | t }}"
              name="update"
              class="btn secondary-button"
            >
            <input id="cart_submit" type="submit" value="{{ 'cart.general.checkout' | t }}" name="checkout" class="btn">
          </div>

          {% if additional_checkout_buttons and settings['enable-additional-checkout-buttons'] %}
            <div class="additional-checkout-buttons additional-checkout-buttons--vertical">
              {{ content_for_additional_checkout_buttons }}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </form>

  <script type="application/json" id="initial-cart">
    {{ cart | json }}
  </script>

  <script>
    (function () {
      'use strict';

      function removeGroupedItems(line, groupId) {
        if (!groupId) {
          window.location.href = '{{ routes.cart_url }}/change?line=' + line + '&quantity=0';
          return;
        }

        fetch('{{ routes.cart_url }}.js')
          .then(function (r) {
            return r.json();
          })
          .then(function (cart) {
            var updates = {};
            cart.items.forEach(function (item, idx) {
              var itemGroup = item.properties && (item.properties._group_id || item.properties['Group ID']);
              if (itemGroup && String(itemGroup) === String(groupId) && item.key) {
                updates[item.key] = 0;
              }
            });

            if (!Object.keys(updates).length) {
              window.location.href = '{{ routes.cart_url }}/change?line=' + line + '&quantity=0';
              return null;
            }

            return fetch('{{ routes.cart_url }}/update.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ updates: updates }),
            });
          })
          .then(function () {
            window.location.reload();
          })
          .catch(function () {
            window.location.href = '{{ routes.cart_url }}/change?line=' + line + '&quantity=0';
          });
      }

      function updateGroupedQuantity(groupId, qty) {
        if (!groupId) return Promise.resolve(false);
        if (isNaN(qty) || qty < 1) qty = 1;

        return fetch('{{ routes.cart_url }}.js')
          .then(function (r) {
            return r.json();
          })
          .then(function (cart) {
            var updates = {};
            cart.items.forEach(function (item) {
              var itemGroup = item.properties && (item.properties._group_id || item.properties['Group ID']);
              if (itemGroup && String(itemGroup) === String(groupId) && item.key) {
                updates[item.key] = qty;
              }
            });

            if (!Object.keys(updates).length) return false;

            return fetch('{{ routes.cart_url }}/update.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ updates: updates }),
            }).then(function () {
              return true;
            });
          });
      }

      function syncHiddenEndcapInputs(groupId, qty) {
        document
          .querySelectorAll('input.linked-endcap-quantity-input[data-group-id="' + groupId + '"]')
          .forEach(function (input) {
            input.value = String(qty);
          });
      }

      document.addEventListener(
        'click',
        function (e) {
          var qtyBtn = e.target.closest('.qty-plus, .qty-minus');
          if (qtyBtn) {
            var controls = qtyBtn.closest('.quantity-controls');
            var qtyInput = controls && controls.querySelector('input.quantity-selector[data-group-id]');
            var groupId = qtyInput && qtyInput.getAttribute('data-group-id');
            if (groupId) {
              e.preventDefault();
              e.stopImmediatePropagation();

              var currentQty = parseInt(qtyInput.value, 10);
              if (isNaN(currentQty) || currentQty < 1) currentQty = 1;
              var nextQty = qtyBtn.classList.contains('qty-plus') ? currentQty + 1 : Math.max(1, currentQty - 1);

              qtyInput.value = String(nextQty);
              syncHiddenEndcapInputs(groupId, nextQty);

              updateGroupedQuantity(groupId, nextQty)
                .then(function () {
                  window.location.reload();
                })
                .catch(function () {
                  window.location.reload();
                });
              return;
            }
          }

          var link = e.target.closest('.js-group-remove');
          if (!link) return;
          e.preventDefault();
          removeGroupedItems(link.getAttribute('data-line'), link.getAttribute('data-group-id'));
        },
        true
      );

      document.addEventListener(
        'change',
        function (e) {
          if (e.target && e.target.matches('input.quantity-selector[data-group-id]')) {
            var groupId = e.target.getAttribute('data-group-id');
            if (!groupId) return;
            e.preventDefault();
            e.stopImmediatePropagation();

            var qty = parseInt(e.target.value, 10);
            if (isNaN(qty) || qty < 1) qty = 1;
            e.target.value = String(qty);
            syncHiddenEndcapInputs(groupId, qty);

            updateGroupedQuantity(groupId, qty)
              .then(function () {
                window.location.reload();
              })
              .catch(function () {
                window.location.reload();
              });
          }
        },
        true
      );
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Cart template",
  "class": "container cart-page-template",
  "settings": []
}
{% endschema %}
