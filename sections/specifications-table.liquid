                      or block.settings.row1_column2 != blank
                      or block.settings.row1_column3 != blank
                      or block.settings.row1_column4 != blank
                    %}
                      <tr>
                        {% if block.settings.row1_column2 != blank %}
                          <td>{{ block.settings.row1_column1 }}</td>
                          <td>{{ block.settings.row1_column2 }}</td>
                        {% endif %}
                        {% if block.settings.row1_column4 != blank %}
                          <td>{{ block.settings.row1_column3 }}</td>
                          <td>{{ block.settings.row1_column4 }}</td>
                        {% endif %}
                      </tr>
                    {% endif %}

                    {% if block.settings.row2_column1 != blank
                      or block.settings.row2_column2 != blank
                      or block.settings.row2_column3 != blank
                      or block.settings.row2_column4 != blank
                    %}
