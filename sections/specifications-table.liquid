{% schema %}
{
  "name": "Specifications table",
  "tag":"section",
  "class":"desTable section sec-gapTopSm sec-gapBottom grayBg",
  "settings": [
     {
      "type": "text",
      "id": "button_lebel",
      "label": "Button Lebel"
    },
    {
      "type": "text",
      "id": "dimensions_lebel",
      "label": "Dimension Lebel",
      "default":"Dimensions"
    },
    {
      "type": "text",
      "id": "details_lebel",
      "label": "Details Lebel",
      "default":"Details"
    },
    {
      "type": "text",
      "id": "warranty_lebel",
      "label": "Warranty Lebel",
      "default":"WARRANTY / CERTIFICATIONS"
    }
 ],
  
  "presets": [
  {
    "name": "Specifications table"
  }
]
}
{% endschema %}
