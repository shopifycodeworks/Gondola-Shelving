      			</a>
      		</li>
      	{% endif %}

      	{% if settings.sm_youtube_link != blank %}
      		<li class="sm-youtube wow fadeInUp">
      			<a href="{{ settings.sm_youtube_link }}" target="_blank">
      				<svg role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><title>YouTube icon</title><path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>
      			</a>
      		</li>
      	{% endif %}

      	{% if settings.sm_vimeo_link != blank %}
      		<li class="sm-vimeo wow fadeInUp">
      			<a href="{{settings.sm_vimeo_link}}" target="_blank">
      				<svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><title>Vimeo icon</title><path d="M23.977 6.416c-.105 2.338-1.739 5.543-4.894 9.609-3.268 4.247-6.026 6.37-8.29 6.37-1.409 0-2.578-1.294-3.553-3.881L5.322 11.4C4.603 8.816 3.834 7.522 3.01 7.522c-.179 0-.806.378-1.881 1.132L0 7.197c1.185-1.044 2.351-2.084 3.501-3.128C5.08 2.701 6.266 1.984 7.055 1.91c1.867-.18 3.016 1.1 3.447 3.838.465 2.953.789 4.789.971 5.507.539 2.45 1.131 3.674 1.776 3.674.502 0 1.256-.796 2.265-2.385 1.004-1.589 1.54-2.797 1.612-3.628.144-1.371-.395-2.061-1.614-2.061-.574 0-1.167.121-1.777.391 1.186-3.868 3.434-5.757 6.762-5.637 2.473.06 3.628 1.664 3.493 4.797l-.013.01z"/></svg>
      			</a>
      		</li>
      	{% endif %}

      	{% if settings.sm_tiktok_link != blank %}
      		<li class="sm-tiktok wow fadeInUp">
      			<a href="{{settings.sm_tiktok_link}}" target="_blank">
      				<svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><title>TikTok icon</title><path d="M12.53.02C13.84 0 15.14.01 16.44 0c.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
      			</a>
      		</li>
      	{% endif %}

      	{% if settings.sm_pinterest_link != blank %}
      		<li class="sm-pinterest wow fadeInUp">
      			<a href="{{settings.sm_pinterest_link}}" target="_blank">
      				<svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><title>Pinterest icon</title><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z"/></svg>
      			</a>
      		</li>
      	{% endif %}

      	{% if settings.sm_snapchat_link != blank %}
      		<li class="sm-snapchat wow fadeInUp">
      			<a href="{{settings.sm_snapchat_link}}" target="_blank">
      				<svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><title>Snapchat icon</title><path d="M12.206.793c.99 0 4.347.276 5.93 3.821.529 1.193.403 3.219.299 4.847l-.003.06c-.012.18-.022.345-.03.51.075.045.203.09.401.09.3-.016.659-.12 1.033-.301.165-.088.344-.104.464-.104.182 0 .359.029.509.09.45.149.734.479.734.838.015.449-.39.839-1.213 1.168-.089.029-.209.075-.344.119-.45.135-1.139.36-1.333.81-.09.224-.061.524.12.868l.015.015c.06.136 1.526 3.475 4.791 4.014.255.044.435.27.42.509 0 .075-.015.149-.045.225-.24.569-1.273.988-3.146 1.271-.059.091-.12.375-.164.57-.029.179-.074.36-.134.553-.076.271-.27.405-.555.405h-.03c-.135 0-.313-.031-.538-.074-.36-.075-.765-.135-1.273-.135-.3 0-.599.015-.913.074-.6.104-1.123.464-1.723.884-.853.599-1.826 1.288-3.294 1.288-.06 0-.119-.015-.18-.015h-.149c-1.468 0-2.427-.675-3.279-1.288-.599-.42-1.107-.779-1.707-.884-.314-.045-.629-.074-.928-.074-.54 0-.958.089-1.272.149-.211.043-.391.074-.54.074-.374 0-.523-.224-.583-.42-.061-.192-.09-.389-.135-.567-.046-.181-.105-.494-.166-.57-1.918-.222-2.95-.642-3.189-1.226-.031-.063-.052-.15-.055-.225-.015-.243.165-.465.42-.509 3.264-.54 4.73-3.879 4.791-4.02l.016-.029c.18-.345.224-.645.119-.869-.195-.434-.884-.658-1.332-.809-.121-.029-.24-.074-.346-.119-1.107-.435-1.257-.93-1.197-1.273.09-.479.674-.793 1.168-.793.146 0 .27.029.383.074.42.194.789.3 1.104.3.234 0 .384-.06.465-.105l-.046-.569c-.098-1.626-.225-3.651.307-4.837C7.392 1.077 10.739.807 11.727.807l.419-.015h.06z"/></svg>
      			</a>
      		</li>
      	{% endif %}

      	{% if settings.sm_houzz_link != blank %}
      		<li class="sm-houzz wow fadeInUp">
      			<a href="{{settings.sm_houzz_link}}" target="_blank">
      				<svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><title>Houzz icon</title><path d="M18.93 12v8L12 24v-8.002L5.07 20V3.998L12 0v8l-6.928 4L12 15.998V8l6.93-4.002V12z"/></svg>
      			</a>
      		</li>
      	{% endif %}

      	{% if settings.sm_tumblr_link != blank %}
      		<li class="sm-tumblr wow fadeInUp">
      			<a href="{{settings.sm_tumblr_link}}" target="_blank">
      				<svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><title>Tumblr icon</title><path d="M14.563 24c-5.093 0-7.031-3.756-7.031-6.411V9.747H5.116V6.648c3.63-1.313 4.512-4.596 4.71-6.469C9.84.051 9.941 0 9.999 0h3.517v6.114h4.801v3.633h-4.82v7.47c.016 1.001.375 2.371 2.207 2.371h.09c.631-.02 1.486-.205 1.936-.419l1.156 3.425c-.436.636-2.4 1.374-4.156 1.404h-.178l.011.002z"/></svg>
      			</a>
      		</li>
      	{% endif %}

      	{% if settings.sm_linkedin_link != blank %}
      		<li class="sm-linkedin wow fadeInUp">
      			<a href="{{settings.sm_linkedin_link}}" target="_blank">
      				<svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><title>LinkedIn icon</title><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      			</a>
      		</li>
      	{% endif %}

			</ul>
              </div>
            </div>

          {% when 'social' %}
            <div class="{{ footer_item_width }} footer-block--wrapper" {{ block.shopify_attributes }}>
              <h3 class="type-subheading type-subheading--1">{{ block.settings.menu_title | escape }}</h3>
              <div class="footer__social-icons">
                {% render 'social-links' %}
              </div>
            </div>

          {% when 'block' %}
            <div class="{{ footer_item_width }} footer_sotr_blk footer-block--wrapper" {{ block.shopify_attributes }}>
              <div class="footer-wrape">
                {% if block.settings.store_label != '' %}
                  <h3 class="type-subheading type-subheading--1">{{ block.settings.store_label | escape }}</h3>
                {% endif %}
                <div class="vision_outer">
                  {% if block.settings.visionpage1 != '' %}
                    <div class="store_items">
                      <img
                        src="{{ block.settings.visionpage1.metafields.custom.first_image  | img_url: 'master' }}"
                        alt="{{ block.settings.visionpage1.metafields.custom.first_image.alt }}"
                      >
                      <a href="/pages/{{  block.settings.visionpage1.handle }}">
                        {{- block.settings.visionpage1.title -}}
                      </a>
                    </div>
                  {% endif %}
                  {% if block.settings.visionpage2 != '' %}
                    <div class="store_items">
                      <img
                        src="{{ block.settings.visionpage2.metafields.custom.first_image  | img_url: 'master' }}"
                        alt="{{ block.settings.visionpage2.metafields.custom.first_image.alt }}"
                      >
                      <a href="/pages/{{  block.settings.visionpage2.handle }}">
                        {{- block.settings.visionpage2.title -}}
                      </a>
                    </div>
                  {% endif %}
                  {% if block.settings.visionpage3 != '' %}
                    <div class="store_items">
                      <img
                        src="{{ block.settings.visionpage3.metafields.custom.first_image  | img_url: 'master' }}"
                        alt="{{ block.settings.visionpage3.metafields.custom.first_image.alt }}"
                      >
                      <a href="/pages/{{  block.settings.visionpage3.handle }}">
                        {{- block.settings.visionpage3.title -}}
                      </a>
                    </div>
                  {% endif %}
                  <div class="see_more_btn">
                    <a href="{{ block.settings.view_all_btnul }}">{{ block.settings.view_all_btnxt }}</a>
                  </div>
                </div>
              </div>
            </div>

          {% when 'image' %}
            <div
              class="{{ footer_item_width }} footer-image-id--{{ block.id }} image-footer footer-block--wrapper"
              {{ block.shopify_attributes }}
            >
              <div class="footer-wrape">
                {% if block.settings.title != '' %}
                  <h3 class="type-subheading type-subheading--1">{{ block.settings.title }}</h3>
                {% endif %}

                {% if block.settings.image != blank %}
                  {%- assign img_url = block.settings.image | img_url: 'master' -%}
                {% else %}
                  {%- assign img_url = '' -%}
                {% endif %}
                {% if block.settings.link != blank and img_url != blank %}
                  <a href="{{ block.settings.link }}">
                {% elsif img_url != blank %}
                  <div class="image-bar__item">
                {% else %}
                  <div class="image-bar__item">
                {% endif %}
                <div class="image-bar__content">
                  {% if img_url == blank %}
                    <div class="footer_logo1">
                      {{ 'image' | placeholder_svg_tag: 'icon icon--placeholder' }}
                    </div>
                  {% else %}
                    <div class="footer_logo1">
                      {% capture image_styles %}max-width: {{ block.settings.image.width }}px;{% endcapture %}
                      {% capture alt %}{{ block.settings.image.alt }}{% endcapture %}
                      {% render 'responsive-image' with block.settings.image, styles: image_styles, alt: alt %}
                    </div>
                  {% endif %}
                </div>
                {% if block.settings.link != blank and img_url != blank %}
                  </a>
                {% else %}
                  </div>
                {% endif %}
                <!--
                  {% if block.settings.show_methods_of_payment %}
                      <ul id="footer-payment-methods" class="inline-list payment-icons">
                          <li><img src="https://cdn.shopify.com/s/files/1/0790/3094/4025/files/Mask_group_27.png?v=1689171746" class="payment-icon" /></li>
                        <li><img src="https://cdn.shopify.com/s/files/1/0790/3094/4025/files/Mask_group_26.png?v=1689171745" class="payment-icon" /></li>
                        <li><img src="https://cdn.shopify.com/s/files/1/0790/3094/4025/files/Mask_group_28.png?v=1689171745" class="payment-icon" /></li>
                        <li><img src="https://cdn.shopify.com/s/files/1/0790/3094/4025/files/Mask_group_29.png?v=1689171745" class="payment-icon" /></li>
                        <li><img src="https://cdn.shopify.com/s/files/1/0790/3094/4025/files/Mask_group_31.png?v=1689171745" class="payment-icon" /></li>
                        <li><img src="https://cdn.shopify.com/s/files/1/0790/3094/4025/files/Mask_group_30.png?v=1689171745" class="payment-icon" /></li>
                      </ul>
                  {% endif %}
                -->
                {% if section.settings.footer_logo != blank %}
                  <div class="footer_logo2">
                    <img src="{{ section.settings.footer_logo | img_url: 'medium' }}">
                  </div>
                {% endif %}
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  </div>

</footer>

{% style %}
  @media (max-width: 768px) {
      {% if section.settings.alignment == 'center' %}
          footer #newsletter-wrapper:not(.password-form#newsletter-wrapper) input {
              margin-left: 55px; // To compensate for the button
          }
      {% else %}
          footer #newsletter-wrapper:not(.password-form#newsletter-wrapper) {
              justify-content: flex-start;
          }
      {% endif %}
  }
{% endstyle %}


