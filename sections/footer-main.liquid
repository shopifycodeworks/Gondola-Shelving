{{ 'section-newsletter.min.css' | asset_url | stylesheet_tag }}

{% capture section_style_attr %}
  style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;"
{% endcapture %}

{% case section.settings.colors %}
  {% when 'white' %}
    <section class="homepage-sections-wrapper homepage-sections-wrapper--white" {{ section_style_attr }}>
  {% when 'light' %}
    <section class="homepage-sections-wrapper homepage-sections-wrapper--light" {{ section_style_attr }}>
  {% when 'accent' %}
    <section class="homepage-sections-wrapper homepage-sections-wrapper--accent" {{ section_style_attr }}>
  {% when 'dark' %}
    <section class="homepage-sections-wrapper homepage-sections-wrapper--dark" {{ section_style_attr }}>
{% endcase %}

{% assign title = false %}
{% if section.settings.title != blank
  or section.settings.subheading != blank
  or section.settings.newsletter_description != blank
%}
  {% assign title = true %}
{% endif %}

{% assign footer_item_width = '' %}
{% case section.blocks.size %}
  {% when 1 %}
    {% assign footer_item_width = 'col-md-12 col-sm-12' %}
  {% when 2 %}
    {% assign footer_item_width = 'col-md-6 col-sm-12' %}
  {% when 3 %}
    {% assign footer_item_width = 'col-md-4 col-sm-12' %}
  {% when 4 %}
    {% assign footer_item_width = 'col-md-3 col-6' %}
{% endcase %}

<footer class="footer-main" data-wetheme-section-type="footer-main" data-wetheme-section-id="{{ section.id }}">
  <div class="container">
    <div class="row footer-alignment--{{ section.settings.alignment }}">
      {% for block in section.blocks %}
        {% if block.type == 'image' %}
          <style>
            .footer-image-id--{{ block.id }} img {
            	width: {{ block.settings.image_max_width }}%;
            }
          </style>
        {% endif %}

        {% case block.type %}
          {% when 'menu' %}
            {%- assign footer_linklist = block.settings.footer_linklist -%}
            <div class="{{ footer_item_width }} links-footer footer-block--wrapper" {{ block.shopify_attributes }}>
              <div class="footer-wrape">
                <h5 class="type-subheading type-subheading--1">{{ block.settings.menu_title | escape }}</h5>

                {% if linklists[footer_linklist].links.size > 0 %}
                  <nav>
                    <ul>
                      {% for link in linklists[footer_linklist].links %}
                        <li
                          {% if link.object.tags and link.object.tags.size > 0 %}
                            class="children"
                          {% endif %}
                        >
                          <a href="{{link.url}}">{{ link.title }}</a>
                        </li>
                      {% endfor %}
                    </ul>
                  </nav>
                {% endif %}
              </div>
            </div>

          {% when 'text' %}
            <div class="{{ footer_item_width }} content-footer footer-block--wrapper" {{ block.shopify_attributes }}>
              <div class="footer-wrape">
                <h5 class="type-subheading type-subheading--1">{{ block.settings.title | escape }}</h5>
                <div class="rte footer-article">{{ block.settings.richtext }}</div>
              </div>
            </div>

          {% when 'newsletter' %}
            <div
              class="{{ footer_item_width }} mailing-list-footer footer-block--wrapper ftNewsletter"
              {{ block.shopify_attributes }}
            >
              <h3 class="type-subheading type-subheading--1">{{ block.settings.menu_title | escape }}</h3>
              {% if block.settings.footer_newsletter_description != empty %}
                <div class="rte">{{ block.settings.footer_newsletter_description }}</div>
              {% endif %}

              {% render 'newsletter-form' %}

              <div class="socialIconsWrap">
                <div class="footer-wrape">
                  <h5 class="type-subheading type-subheading--1">{{ block.settings.social_icons_heading | escape }}</h5>
                </div>
              {% if settings.sm_facebook_link == blank and
        settings.sm_twitter_link == blank and
        settings.sm_instagram_link == blank and
        settings.sm_youtube_link == blank and
        settings.sm_vimeo_link == blank and
        settings.sm_tiktok_link == blank and
        settings.sm_pinterest_link == blank and
        settings.sm_snapchat_link == blank and
        settings.sm_houzz_link == blank and
        settings.sm_tumblr_link == blank and
        settings.sm_linkedin_link == blank %}
        <p class="homepage-section-social-media--onboarding">{{ 'general.onboarding.no_socials' | t }}</p>
      {% endif %}

			<ul class="homepage-section-social-media animated-auto-list {% if section.settings.icon-colors == 'color' %}homepage-section-social-media--color{% else %}homepage-section-social-media--black-and-white{% endif %}">

        {% if settings.sm_facebook_link != blank %}
      		<li class="sm-facebook wow fadeInUp">
      			<a href="{{ settings.sm_facebook_link }}" target="_blank">
      				<svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><title>Facebook icon</title><path d="M22.676 0H1.324C.593 0 0 .593 0 1.324v21.352C0 23.408.593 24 1.324 24h11.494v-9.294H9.689v-3.621h3.129V8.41c0-3.099 1.894-4.785 4.659-4.785 1.325 0 2.464.097 2.796.141v3.24h-1.921c-1.5 0-1.792.721-1.792 1.771v2.311h3.584l-.465 3.63H16.56V24h6.115c.733 0 1.325-.592 1.325-1.324V1.324C24 .593 23.408 0 22.676 0"/></svg>
      			</a>
      		</li>
      	{% endif %}

      	{% if settings.sm_twitter_link != blank %}
      		<li class="sm-twitter wow fadeInUp">
      			<a href="{{ settings.sm_twitter_link }}" target="_blank">
      				<img
            src="https://cdn.shopify.com/s/files/1/0784/4941/0346/files/New_Project.png?v=1707488631"
            >      			</a>
      		</li>
      	{% endif %}

      	{% if settings.sm_instagram_link != blank %}
      		<li class="sm-instagram wow fadeInUp">
      			<a href="{{ settings.sm_instagram_link }}" target="_blank">
