{{ 'section-info-columns.min.css' | asset_url | stylesheet_tag }}

{% assign post_limit = section.settings.post_limit %}

{%- capture post_limit_grid -%}
  {%- case post_limit -%}
    {%- when 1 -%}
      {%- assign grid_item_width = 'col-md-6 offset-md-3' -%}
    {%- when 2 -%}
      {%- assign grid_item_width = 'col-md-6' -%}
    {%- when 3 -%}
      {%- assign grid_item_width = 'col-md-4' -%}
    {%- when 4 -%}
      {%- assign grid_item_width = 'col-md-3' -%}
  {%- endcase -%}
{%- endcapture -%}

{% capture section_style_attr %}
  style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;"
{% endcapture %}

{% case section.settings.colors %}
  {% when 'white' %}
    <section class="homepage-sections-wrapper homepage-sections-wrapper--white blog-vision-sec" {{ section_style_attr }}>
  {% when 'light' %}
    <section class="homepage-sections-wrapper homepage-sections-wrapper--light" {{ section_style_attr }}>
  {% when 'accent' %}
    <section class="homepage-sections-wrapper homepage-sections-wrapper--accent" {{ section_style_attr }}>
  {% when 'dark' %}
    <section class="homepage-sections-wrapper homepage-sections-wrapper--dark" {{ section_style_attr }}>
{% endcase %}
<div class="container">
  {% if section.settings.label_heading != blank %}
    <h2 class="text-center">{{ section.settings.label_heading }}</h2>
  {% endif %}
  <div class="swiper-container">
    <div class="row">
       {% for block in section.blocks %}
        <div class="{{ grid_item_width }}">
           
              <div class="info-column grid__item">
                <div class="home-blog-col">
                <a href="{{ block.settings.page_link }}">
                  {% if block.settings.page_image != blank %}
                    <div class="store-image">
                      {% include 'responsive-image' with block.settings.page_image, alt: block.settings.page_image.alt %}
                    </div>
                  {% endif %}
                  {% if block.settings.page_title != 'blank' %}
                    <h4 class="type-heading type-heading--1 info-columns--title">{{ block.settings.page_title }}</h4>
                  {% endif %}
                </a>
                  </div>
              </div>
           
        </div>
          {% endfor %}
      </div>
    </div>
</div>
{% schema %}
{
    "name": "Store Vision Blogs",
    "tag": "section",
    "class": "homepage-section--blog-posts-wrapper",
    "settings": [
        {
            "type": "select",
            "id": "colors",
            "label": {
                "en": "Color scheme",
                "de": "Farbschema",
                "es": "Esquema de colores",
                "fr": "Palette de couleurs",
                "pt-PT": "Esquema de cores"
            },
            "default": "white",
            "options": [
                {
                    "value": "white",
                    "label": {
                        "en": "White",
                        "de": "Weiß",
                        "es": "Blanco",
                        "fr": "Blanc",
                        "pt-PT": "Branco"
                    }
                },
                {
                    "value": "light",
                    "label": {
                        "en": "Light",
                        "de": "Licht",
                        "es": "Luz",
                        "fr": "Clair",
                        "pt-PT": "Claro"
                    }
                },
                {
                    "value": "accent",
                    "label": {
                        "en": "Feature",
                        "de": "Eigenschaft",
                        "es": "Destacado",
                        "fr": "Caractéristique",
                        "pt-PT": "Funcionalidade"
                    }
                },
                {
                    "value": "dark",
                    "label": {
                        "en": "Dark",
                        "de": "Dunkel",
                        "es": "Oscuro",
                        "fr": "Foncé",
                        "pt-PT": "Escuro"
                    }
                }
            ],
            "info": {
                "en": "Set your color schemes in 'Theme settings' > 'Colors'",
                "de": "Legen Sie Ihre Farbschemata in 'Themeneinstellungen' > 'Farben' fest",
                "es": "Configurar las combinaciones de color en 'Configuración del tema' > 'Colores'",
                "fr": "Définissez vos jeux de couleurs dans « Paramètres du thème » > « Couleurs »",
                "pt-PT": "Defina os seus esquemas de cor em 'Definições de tema' > 'Cores'"
            }
        },
      {
        "type": "text",
        "id": "label_heading",
        "label": "Heading"
      },
        {
            "type": "range",
            "id": "post_limit",
            "min": 1,
            "max": 4,
            "step": 1,
            "label": "Pages",
            "default": 3
        },
        {
          "type": "header",
          "content": "Section spacing"
        },
        {
          "type": "select",
          "id": "section_width",
          "label": "Width",
          "options": [
              {
                "value": "container-full-width",
                "label": "Full width"
              },
              {
                "value": "container",
                "label": "Page width"
              }
          ],
          "default": "container"
        },
        {
          "type": "range",
          "id": "padding_top",
          "label": "Padding top",
          "min": 0,
          "max": 200,
          "step": 2,
          "unit": "px",
          "default": 50
        },
        {
          "type": "range",
          "id": "padding_bottom",
          "label": "Padding bottom",
          "min": 0,
          "max": 200,
          "step": 2,
          "unit": "px",
          "default": 50
        }
    ],
    "blocks": [
      {
        "type": "article",
        "name": "Select pages",
        "settings": [
          {
            "type": "image_picker",
            "id": "page_image",
            "label": "Page Image"
          },
          {
            "type": "text",
            "id": "page_title",
            "label": "Page Title"
          },
          {
            "type": "url",
            "id": "page_link",
            "label": "Page Link"
          }
        ]
      }
    ],
    "presets": [
        {
            "name": "Store Vision Blogs"
        }
    ],
    "disabled_on": {
      "groups": ["header", "footer"]
    }
}
{% endschema %}