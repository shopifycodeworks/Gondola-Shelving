<script async src="{{ 'faq.js' | asset_url }}"></script>
<style>
  .accordion-faq--{{ section.id }} {
    color: {{ section.settings.text-color }};
    background-color: {{ section.settings.background-color }};
  }

  .accordion-container .title-bar {
    text-align: left;
    margin-bottom: 10px;
    text-transform: none;
    font-family: var(--body-font-stack);
    font-size: 1.2rem;
  }

  .accordion-content {
    border-bottom: 1px solid {{ section.settings.text-color }};
  }

  .accordion-content a {
    text-decoration: underline;
    color: {{ section.settings.text-color }};
  }

  .accordion-content a:hover {
    text-decoration: none;
  }

  .accordion-faq--{{ section.id }} .feather-x,
  .accordion-faq--{{ section.id }} .feather-chevron-down {
    color: {{ section.settings.text-color }};
  }
</style>
<section class="faq-acc comm-padd">
  <div class="container">
    {% unless section.settings.title == blank %}
        <div class="custom-font text-center">
          {% if section.settings.title != blank %}
            <h2>{{ section.settings.title }}</h2>
          {% endif %}
          {% if section.settings.sub_heading != blank %}
            <p>{{ section.settings.sub_heading }}</p>
          {% endif %}
        </div>
      {% endunless %}
      <ul class="accordion" id="accordion">
        {% assign variable = 1 %}
          {% for block in section.blocks %}
            <li class="accordion__item">
                <div class="accordion__link js-accordion-link">  <span class="acc-num">{{ variable }}.</span>{{ block.settings.question }}</div>
                <div class="accordion__submenu js-accordion-submenu">
                    <p>{{ block.settings.text }}</p>
                </div>
            </li>
          {% assign variable = variable | plus: 1 %}
        {% endfor %}
    </ul>
  </div>
</section>


{% schema %}
  {
    "name": "FAQ",
    "tag": "section",
    "class": "main-accordion--wrapper",
    "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "sub_heading",
          "label": "Sub Heading"
        },
        {
          "type": "radio",
          "id": "faq_icon",
          "label": {
              "en": "Icon style"
          },
          "options": [
              {
                  "value": "plus_minus",
                  "label": {
                      "en": "Plus/minus"
                  }
              },
              {
                  "value": "caret",
                  "label": {
                      "en": "Caret"
                  }
              }
          ],
          "default": "plus_minus"
        },
        {
          "type": "header",
          "content": "Section spacing"
        },
        {
          "type": "select",
          "id": "section_width",
          "label": "Width",
          "options": [
              {
                "value": "container-full-width",
                "label": "Full width"
              },
              {
                "value": "container",
                "label": "Page width"
              },
              {
                "value": "container-narrow",
                "label": "Narrow"
              }
          ],
          "default": "container"
        },
        {
          "type": "range",
          "id": "padding_top",
          "label": "Padding top",
          "min": 0,
          "max": 200,
          "step": 2,
          "unit": "px",
          "default": 50
        },
        {
          "type": "range",
          "id": "padding_bottom",
          "label": "Padding bottom",
          "min": 0,
          "max": 200,
          "step": 2,
          "unit": "px",
          "default": 50
        }
    ],
    "blocks": [
      {
        "type": "tab_content",
        "name": {
            "en": "Tab content"
        },
        "settings": [
          {
            "type": "text",
            "id": "question",
            "label": {
                "en": "Heading",
                "de": "Überschrift",
                "es": "Encabezado",
                "fr": "Rubrique",
                "pt-PT": "Título"
            }
          },
          {
            "type": "richtext",
            "id": "text",
            "label": {
                "en": "Text",
                "de": "Text",
                "es": "Texto",
                "fr": "Texte",
                "pt-PT": "Texto"
            }
          }
        ]
      }
    ],
    "presets": [
        {
            "name": "FAQ"
        }
    ],
    "disabled_on": {
      "groups": ["header"]
    }
  }
    {% endschema %}