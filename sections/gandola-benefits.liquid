{% comment %}
<style>
  .scroller1 {
    max-width: 100%;
  }

  .scroller__inner1 {
    //padding-block: 1rem;
    display: flex;
    flex-wrap: wrap;
    //gap: 1rem;
  }

  .scroller1[data-animated="true"] {
    overflow: hidden;
  //  -webkit-mask: linear-gradient(
      90deg,
      transparent,
      white 20%,
      white 80%,
      transparent
    );
  //  mask: linear-gradient(90deg, transparent, white 20%, white 80%, transparent);
  }

  .scroller1[data-animated="true"] .scroller__inner1 {
    width: max-content;
    flex-wrap: nowrap;
    animation: scroll var(--_animation-duration, 40s)
      var(--_animation-direction, forwards) linear infinite;
  }

  .scroller1[data-direction="right"] {
    --_animation-direction: reverse;
  }

  .scroller1[data-direction="left"] {
    --_animation-direction: forwards;
  }

  .scroller1[data-speed="fast"] {
    --_animation-duration: 30s;
  }

  .scroller1[data-speed="slow"] {
    --_animation-duration: 60s;
  }

  @keyframes scroll {
    to {
      transform: translate(calc(-50% - 0.5rem));
    }
  }

  /* general styles */

  :root {
    --clr-neutral-100: hsl(0, 0%, 100%);
    --clr-primary-100: hsl(205, 15%, 58%);
    --clr-primary-400: hsl(215, 25%, 27%);
    --clr-primary-800: hsl(217, 33%, 17%);
    --clr-primary-900: hsl(218, 33%, 9%);
  }

  .tag-list {
    margin: 0;
    padding-inline: 0;
    list-style: none;
  }

  .tag-list li {
    padding: 1rem;
    background: var(--clr-primary-400);
    border-radius: 0.5rem;
    box-shadow: 0 0.5rem 1rem -0.25rem var(--clr-primary-900);
  }

  /* for testing purposed to ensure the animation lined up correctly */
  .test {
    background: red !important;
  }

.scroller1[data-animated="true"] .scroller__inner1:hover {
  animation-play-state: paused;
}
       .scroller1[data-animated="true"] .scroller__inner1 .item {
      //  min-width: 25% !important;
         width: 450px;
    }
  
  .benefits-icons .col-lg-4.p-0 {
    padding: 0 20px !important;
}
  .benefits-icons .heading{
    text-align: center;
    margin-bottom: 35px !important
  }
  .benefits-icons .benefits-col-wrap {
    text-align: center;
}
  .benefits-icons .benefits-col-wrap .image_content {
    //background: #CC0000;
    height: 75px;
    width: 75px;
    margin: 0 auto;
    border-radius: 50%;
    //padding: 20px;
}
  .benefits-icons .benefits-col-wrap span.benefits_heading {
    font-size: 18px;
    font-weight: bold;
    text-transform: uppercase;
}
  .benefits-icons .benefits_data {
    margin-top: 10px;
}
span.benefits_content p {
    clear: both;
    font-size: 12px !important;
    padding: 10px 0;
}
  .benefits-icons .common-btnBtn-bookConsultation.text-center a.common-btn {
    font-weight: 600 !important;
    letter-spacing: 0;
    font-size: 20px !important;
    border-radius: 0 !important;
    padding-left: 20px;
    border: 2px solid #000;
}
  .benefits-icons .common-btn.btn.btnBlack.btnLg{
