<div class="p-0 {{ section.settings.custom_class }}" {{ section_style_attr }}>
      <div class="col-lg-12 p-0">
        <div class="half_data">
            {% if section.settings.heading != blank %}
              <h1 class="benefits_heading">
                {{ section.settings.heading }}
              </h1>
            {% endif %}
            {% if section.settings.text_cont != blank %}
              <span class="text_content">
                {{ section.settings.text_cont }}
              </span>
            {% endif %}
          {% comment %}
          <button class="button globo-formbuilder-open btn" data-id="NDU2Nzk=">Book A Consultation</button>
          {% endcomment %}
            {% if section.settings.button_label != blank and section.settings.button_link != blank %}
                  <div class="common-btnBtn-bookConsultation text-center">
                    <a href="javascript:;" class="common-btn btn btnBlack btnLg" id="viewForm">
                      {{- section.settings.button_label -}}
                    </a>
                  </div>
<div id="myForm1" class="modal">
  <div class="modal-content">
    <span class="closing2">&times;</span>
    
            <div class="contact-form-wrap " style="visibility: visible !important;">
              <h2>RECEIVE A FREE CONSULTATION</h2>
              {% comment %}
              <p class="type-subheading type-subheading--1">Contact us today to receive help in creating the perfect retail space for your business, that not only attracts and retains customers, but also promotes efficient business operations. Receive your free consultation within within 24 hours.</p>
              {% endcomment %}
              <p class="type-subheading type-subheading--1">Our trusted team will gladly help with all your project needs.</p>
              {% form 'contact', id: 'ContactForm', class: 'contact-form--form' %}
                {%- if form.posted_successfully? -%}
                  <script>
                    window.location.replace("https://vanguardstorefixtures.com/pages/thank-you");
                  </script>
                {%- endif -%}
                {% render 'form-errors-custom', form: form %}
                {% if form.posted_successfully? %}
                  <div class="w-full">
                    <p class="note form-success">
                      {{ 'contact.form.post_success' | t }}
                    </p>
                  </div>
                {% endif %}

                      <div class="input-wrapper w-half ggright">
                        {% liquid
                          assign nameInputString = 'contact.form.name' | t
                          assign formName = 'contact[' | append: nameInputString | append: ']'
                          assign labelInput = nameInputString | prepend: requiredSymbol
                          assign formId = 'form_' | append: nameInputString | downcase | handleize
                          assign input_attr = 'aria-labelledby="' | append: formId | append: '" data-aid="name-input"'
                          if form.name
                            assign nameInputVal = form.name
                          elsif customer
                            assign nameInputVal = customer.name
                          endif

                          render 'form-input' with type: 'text', has_label: true, animate_label: false, id: formId, value: nameInputVal, name: formName, required: true, attributes: input_attr , placeholder: "Name*"
                        %}
                      </div>
                
                      <div class="input-wrapper w-half">
                        {% liquid
                          assign companyInputString = 'contact.form.name' | t
                          assign formName = 'contact[' | append: companyInputString | append: ']'
                          assign labelInput = companyInputString | prepend: requiredSymbol
                          assign formId = 'form_' | append: companyInputString | downcase | handleize
                          assign input_attr = 'aria-labelledby="' | append: formId | append: '" data-aid="company-input"'
                          if form.company
                            assign companyInputVal = form.name
                          elsif customer
                            assign companyInputVal = customer.name
                          endif

                          render 'form-input' with type: 'text', has_label: true, animate_label: false, id: formId, value: companyInputVal, name: formName, required: block.settings.required, attributes: input_attr , placeholder: "Company"
                        %}
                      </div>

                      <div class="input-wrapper w-half ggright">
                        {% liquid
                          assign telInputString = 'contact.form.phone' | t
                          assign formTelName = 'contact[' | append: telInputString | append: ']'
                          assign labelInput = telInputString | prepend: requiredSymbol
                          assign formId = 'form_' | append: telInputString | downcase | handleize
                          assign input_attr = 'aria-labelledby="' | append: formId | append: '" data-aid="tel-input"'
                          if form.phone
                            assign phoneInputVal = form.phone
                          elsif customer
                            assign phoneInputVal = customer.phone
                          endif

                          render 'form-input' with type: 'tel', has_label: true, animate_label: false, id: formId, value: phoneInputVal, name: formTelName, required: true, attributes: input_attr , placeholder: "Phone*"
                        %}
                      </div>

                      <div class="input-wrapper w-half">
                        {% liquid
                          assign emailInputString = 'contact.form.email' | t
                          assign formEmailName = 'contact[' | append: emailInputString | downcase | append: ']'
                          assign labelInput = emailInputString | prepend: requiredSymbol
                          assign formId = 'form_' | append: emailInputString | downcase | handleize
                          assign input_attr = 'aria-labelledby="' | append: formId | append: '" data-aid="email-input"'
                          if form.email
                            assign emailInputVal = form.email
                          elsif customer
                            assign emailInputVal = customer.email
                          endif

                          render 'form-input' with type: 'email', has_label: true, animate_label: false, id: formId, value: emailInputVal, name: formEmailName, required: true, attributes: input_attr , placeholder: "Email*"
                        %}
                      </div>

                      <div class="input-wrapper w-full">
                        {% liquid
                          assign msgInputString = 'contact.form.message' | t
                          assign formMsgName = 'contact[' | append: msgInputString | append: ']'
                          assign labelInput = msgInputString | prepend: requiredSymbol
                          assign formId = 'form_' | append: msgInputString | downcase | handleize
                          assign input_attr = 'aria-labelledby="' | append: formId | append: '" data-aid="message-input"'

                          render 'form-input--textarea' with id: formId, name: formMsgName, has_label: true, animate_label: false, attributes: input_attr, required: true, content: form.body , placeholder: "What can we help you with?*"
                        %}
                      </div>
                      <div class="input-wrapper w-full custom-file-input">
                        <input type="file" id="contact_file" name="contact[attachment]" accept=".pdf, .dwg, .dxf, .png, .jpg, .jpeg, application/pdf, image/*">

                            <!--input type="file" id="contact_file" name="contact[attachment]" accept="application/pdf,image, .dwg, .dxf, .png, .jpg, .jpeg, .pdf/*" -->
                        <label>Attach any files that will help with the consultation, for example: floor plans, drawings, reference images, design visions, etc.</label>
                <div id="file-label"></div>
                        <input type="hidden" id="image_path" name="contact[file]" value="" />
                      </div>
                      <div class="input-wrapper w-full checkbox_data">
                        <input type="checkbox" id="contact_checkbox" name="contact[terms]" required checked>
                        <label for="contact_checkbox">By submitting this form, I agree to be contacted by Vanguard Store Fixtures Inc. through a phone call, email, or text message.</label>
                      </div>
                <div class="contact-form--submit-wrapper w-full">
                  <input type="submit" class="btn" value="{{ 'contact.form.send' | t }}">
                </div>
              {% endform %}
            </div>
  </div>
</div>



