{% assign footer_item_width = '' %}
{% case section.blocks.size %}
{% when 1 %}
	{% assign footer_item_width = 'col-md-12 col-sm-12' %}
{% when 2 %}
	{% assign footer_item_width = 'col-md-6 col-sm-12' %}
{% when 3 %}
	{% assign footer_item_width = 'col-md-4 col-sm-12' %}
{% when 4 %}
    {% assign footer_item_width = 'col-md-3 col-6' %}
{% endcase %}

<footer class="footer-main ftrBg" data-wetheme-section-type="footer-main" data-wetheme-section-id="{{ section.id }}">
	<div class="container">
		<div class="row footer-alignment--{{ section.settings.alignment }}">
        <div class="col-md-12">
          <div class="ftrRow">
			{% for block in section.blocks %}
			{% if block.type == 'image' %}
			<style>
				.footer-image-id--{{ block.id }} img {
					width: {{ block.settings.image_max_width }}%;
				}
			</style>
			{% endif %}

				{% case block.type %}

					{% when 'menu' %}

						{%- assign footer_linklist = block.settings.footer_linklist -%}
						<div class="{{ footer_item_width }} links-footer footer-block--wrapper" {{ block.shopify_attributes }}>
                          <div class="footer-wrape">
							<h5 class="type-subheading">{{ block.settings.menu_title | escape }}</h5>

        					{% if linklists[footer_linklist].links.size > 0 %}
                            <nav>
                                <ul>
                                    {% for link in linklists[footer_linklist].links %}
                                        <li {% if link.object.tags and link.object.tags.size > 0 %} class="children"{% endif %}>
                                            <a href="{{link.url}}">{{link.title}}</a>
                                        </li>
                                    {% endfor %}
                                </ul>
                            </nav>
							{% endif %}
                          </div>
						</div>

					{% when 'text' %}

						<div class="{{ footer_item_width }} content-footer footer-block--wrapper" {{ block.shopify_attributes }}>
                  <div class="footer-wrape">
							<h5 class="type-subheading">{{ block.settings.title | escape }}</h5>
							<div class="rte footer-article">{{ block.settings.richtext }}</div>
						</div>
                        </div>

					{% when 'newsletter' %}

						<div class="{{ footer_item_width }} mailing-list-footer footer-block--wrapper" {{ block.shopify_attributes }}>
							<h5 class="type-subheading type-subheading--1">{{ block.settings.menu_title | escape }}</h5>
							{% if block.settings.footer_newsletter_description != empty %}
								<div class="rte">{{ block.settings.footer_newsletter_description }}</div>
							{% endif %}

							{% render 'newsletter-form' %}

						</div>

					{% when 'social' %}

						<div class="{{ footer_item_width }} footer-block--wrapper" {{ block.shopify_attributes }}>
							<h5 class="type-subheading">{{ block.settings.menu_title | escape }}</h5>
							<div class="footer__social-icons">
								{% render 'social-links' %}
							</div>
						</div>

                        {% when 'block' %}

						<div class="{{ footer_item_width }} footer_sotr_blk footer-block--wrapper" {{ block.shopify_attributes }}>
                        <div class="footer-wrape">
                          {% if block.settings.store_label != '' %}
							<h5 class="type-subheading">{{ block.settings.store_label | escape }}</h5>
                          {% endif %}
							<div class="vision_outer">
                              {% if block.settings.visionpage1 != '' %}
                                <div class="store_items">
                                  <img src="{{ block.settings.visionpage1.metafields.custom.first_image  | img_url: 'master' }}" alt="{{ block.settings.visionpage1.metafields.custom.first_image.alt }}" />
                                  <a href="/pages/{{  block.settings.visionpage1.handle }}">{{  block.settings.visionpage1.title }}</a>
                                </div>
                              {% endif %}
                              {% if block.settings.visionpage2 != '' %}
                                <div class="store_items">
                                  <img src="{{ block.settings.visionpage2.metafields.custom.first_image  | img_url: 'master' }}" alt="{{ block.settings.visionpage2.metafields.custom.first_image.alt }}" />
                                  <a href="/pages/{{  block.settings.visionpage2.handle }}">{{  block.settings.visionpage2.title }}</a>
                                </div>
                              {% endif %}
                              {% if block.settings.visionpage3 != '' %}
                                <div class="store_items">
                                  <img src="{{ block.settings.visionpage3.metafields.custom.first_image  | img_url: 'master' }}" alt="{{ block.settings.visionpage3.metafields.custom.first_image.alt }}" />
                                  <a href="/pages/{{  block.settings.visionpage3.handle }}">{{  block.settings.visionpage3.title }}</a>
                                </div>
                              {% endif %}
                              <div class="see_more_btn">
                                <a href="{{ block.settings.view_all_btnul }}">{{ block.settings.view_all_btnxt }}</a>
                              </div>
                              
                            </div>
                        </div>
						</div>

						{% when 'image' %}

							<div class="{{ footer_item_width }} footer-image-id--{{ block.id }} image-footer footer-block--wrapper" {{ block.shopify_attributes }}>
                              <div class="footer-wrape">
								{% if block.settings.title != '' %}
									<h5 class="type-subheading">{{ block.settings.title }}</h5>
								{% endif %}

								{% if block.settings.image != blank %}
									{%- assign img_url = block.settings.image | img_url: 'master' -%}
								{% else %}
									{%- assign img_url = '' -%}
								{% endif %}
								{% if block.settings.link != blank and img_url != blank %}
									<a href="{{ block.settings.link }}">
								{% elsif img_url != blank %}
									<div class="image-bar__item">
								{% else %}
									<div class="image-bar__item">
								{% endif %}
								<div class="image-bar__content">
									{% if img_url == blank %}
                                      <div class="footer_logo1">
										{{ 'image' | placeholder_svg_tag: 'icon icon--placeholder' }}
                                      </div>
									{% else %}
                                      <div class="footer_logo1">
										{% capture image_styles %}max-width: {{ block.settings.image.width }}px;{% endcapture %}
                                        {% capture alt %}{{ block.settings.image.alt }}{% endcapture %}
										{% render 'responsive-image' with block.settings.image, styles: image_styles, alt: alt %}
                                      </div>
									{% endif %}
								</div>
								{% if block.settings.link != blank and img_url != blank %}
									</a>
								{% else %}
									</div>
								{% endif %}
<!--                                 {% if block.settings.show_methods_of_payment %}
                                    <ul id="footer-payment-methods" class="inline-list payment-icons">
                                        <li><img src="https://cdn.shopify.com/s/files/1/0790/3094/4025/files/Mask_group_27.png?v=1689171746" class="payment-icon" /></li>
                                      <li><img src="https://cdn.shopify.com/s/files/1/0790/3094/4025/files/Mask_group_26.png?v=1689171745" class="payment-icon" /></li>
                                      <li><img src="https://cdn.shopify.com/s/files/1/0790/3094/4025/files/Mask_group_28.png?v=1689171745" class="payment-icon" /></li>
                                      <li><img src="https://cdn.shopify.com/s/files/1/0790/3094/4025/files/Mask_group_29.png?v=1689171745" class="payment-icon" /></li>
                                      <li><img src="https://cdn.shopify.com/s/files/1/0790/3094/4025/files/Mask_group_31.png?v=1689171745" class="payment-icon" /></li>
                                      <li><img src="https://cdn.shopify.com/s/files/1/0790/3094/4025/files/Mask_group_30.png?v=1689171745" class="payment-icon" /></li>
                                    </ul>
                                {% endif %} -->
                              {% if section.settings.footer_logo != blank %}
                                <div class="footer_logo2">
                                  <img src="{{ section.settings.footer_logo | img_url: 'medium' }}" alt="{{ section.settings.footer_logo.alt | escape }}" />
                                </div>
                              {% endif %}
                                
							</div>
                                    </div>

				{% endcase %}

			{% endfor %}

		</div>
		</div>
		</div>
	</div>
</footer>

{% style %}
        @media (max-width: 768px) {
            {% if section.settings.alignment == 'center' %}
                footer #newsletter-wrapper:not(.password-form#newsletter-wrapper) input {
                    margin-left: 55px; // To compensate for the button
                }
            {% else %}
                footer #newsletter-wrapper:not(.password-form#newsletter-wrapper) {
                    justify-content: flex-start;
                }
            {% endif %}
        }
{% endstyle %}

